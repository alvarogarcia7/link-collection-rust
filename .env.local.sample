# Link Collection Environment Variables (.env.local)
# Copy this file to .env.local in the project root and modify as needed
# This file will override settings from ~/.config/lc/config.toml

# LC_DATABASE_FILE=/path/to/database.rec
# LC_LOG_LEVEL=debug
# LC_TEMPLATE_FILE=/path/to/templates/
# LC_HACKER_NEWS_URL=http://0.0.0.0:8181
